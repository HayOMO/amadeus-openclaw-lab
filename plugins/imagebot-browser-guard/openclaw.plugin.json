{
  "id": "imagebot-browser-guard",
  "name": "Imagebot Browser Guard",
  "description": "Adds the bot browser default profile and permits bot-local media uploads.",
  "version": "0.1.0",
  "enabledByDefault": false,
  "activation": {
    "onStartup": true,
    "onCapabilities": [
      "hook"
    ]
  },
  "hooks": [
    "before_tool_call",
    "after_tool_call"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "allowedProfiles": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "allowedPathPrefixes": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "uploadStagingDir": {
        "type": "string"
      },
      "mediaRoot": {
        "type": "string"
      }
    }
  }
}
