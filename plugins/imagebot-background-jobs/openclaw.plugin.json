{
  "id": "imagebot-background-jobs",
  "name": "Imagebot Background Jobs",
  "description": "Shared in-process queue and status tool for long-running imagebot work.",
  "version": "0.1.0",
  "enabledByDefault": false,
  "activation": {
    "onStartup": true,
    "onCapabilities": [
      "tool",
      "hook"
    ]
  },
  "contracts": {
    "tools": [
      "background_job"
    ],
    "hooks": [
      "before_prompt_build"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "storeDir": {
        "type": "string"
      },
      "maxConcurrent": {
        "type": "number"
      },
      "appendActiveContext": {
        "type": "boolean"
      }
    }
  }
}
