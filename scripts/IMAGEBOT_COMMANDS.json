{
  "version": 4,
  "updatedAt": "2026-06-23",
  "capabilities": [
    {
      "id": "chat",
      "title": "聊天 / 识图",
      "summary": "日常聊天、看图吐槽、读回复里的图片和上下文。",
      "examples": [
        "回复图片说想问什么",
        "@Amadeus 这图哪里怪"
      ]
    },
    {
      "id": "image",
      "title": "生图 / 改图",
      "summary": "生成图片、参考图改图、指定角色时查参考并尽量贴近原设。",
      "examples": [
        "画一个角色",
        "回复图片说按这个姿势重画"
      ]
    },
    {
      "id": "media",
      "title": "文件 / 媒体",
      "summary": "读常见文本、代码、PDF、网页、小视频、GIF、音频转写、音频摘要和关键帧。",
      "examples": [
        "发 PDF 让她总结",
        "回复视频问发生了什么"
      ]
    },
    {
      "id": "web",
      "title": "搜索 / 网页",
      "summary": "搜索资料、搜图、网页截图、公开视频/YouTube 元数据、字幕和受限下载、下载外链图片并保存到本地图库，也能查 Pixiv 榜单和作品资源。",
      "examples": [
        "搜一下这个梗",
        "截一下这个网页",
        "Pixiv daily ranking"
      ]
    },
    {
      "id": "memory",
      "title": "记忆 / 资料库",
      "summary": "维护群友印象、长期资料、角色/风格参考和轻量偏好。",
      "examples": [
        "记住这个角色参考",
        "查一下之前那张图"
      ]
    },
    {
      "id": "play",
      "title": "群玩具",
      "summary": "抽老婆、签到、每日实验、群友自动冒险、图库统计、Telegram贴纸包管理和一些脚本式小玩法。",
      "examples": [
        "抽一次老婆",
        "今日实验"
      ]
    }
  ],
  "commands": [
    {
      "command": "amnew",
      "description": "打开干净的新聊天窗口",
      "usage": "/amnew [message]",
      "category": "session",
      "kind": "runtime",
      "menu": true,
      "notes": "固定运行时命令，在进入普通模型上下文前处理。"
    },
    {
      "command": "amhelp",
      "description": "显示能力和控制命令",
      "usage": "/amhelp [tools|status|model|persona]",
      "category": "ops",
      "kind": "runtime",
      "menu": true,
      "notes": "固定运行时命令，在进入普通模型上下文前处理。"
    },
    {
      "command": "amstatus",
      "description": "查看本地 bot 和会话状态",
      "usage": "/amstatus",
      "category": "ops",
      "kind": "runtime",
      "menu": true,
      "notes": "返回模型、人格、窗口和可用 token 使用量元数据；不暴露 token、路径或原始 session key。"
    },
    {
      "command": "amdeepstatus",
      "description": "Show detailed gateway/security status",
      "usage": "/amdeepstatus",
      "category": "ops",
      "kind": "script",
      "tool": "script_action",
      "scriptId": "gateway_deep_status",
      "menu": false,
      "notes": "Read-only but verbose. Summarize without exposing secrets."
    },
    {
      "command": "ammodel",
      "description": "查看或切换聊天模型",
      "usage": "/ammodel [models|model <provider/model>|model <provider/model> think <level>|think <level>]",
      "category": "ops",
      "kind": "runtime",
      "menu": true,
      "notes": "在进入普通模型上下文前处理。Telegram UI 先选模型，再显示该模型的 thinking levels。"
    },
    {
      "command": "ampersona",
      "description": "查看或切换说话人格",
      "usage": "/ampersona [list|status|set <persona>|default]",
      "category": "session",
      "kind": "runtime",
      "menu": true,
      "notes": "在进入普通模型上下文前处理。切换后打开新人格窗口，并记住发送者默认人格。"
    },
    {
      "command": "amtools",
      "description": "列出安全脚本式控制",
      "usage": "/amtools [list|route <query>|run <id>]",
      "category": "ops",
      "kind": "runtime",
      "menu": true,
      "notes": "固定运行时列表；不会从 Telegram 直接执行维护脚本。"
    },
    {
      "command": "amroll",
      "description": "掷骰，不唤醒模型",
      "usage": "/amroll [NdS]",
      "category": "play",
      "kind": "runtime",
      "menu": true,
      "notes": "进入模型前处理的小命令。例如 /amroll、/amroll 2d6。"
    },
    {
      "command": "amcoin",
      "description": "抛硬币，不唤醒模型",
      "usage": "/amcoin [count]",
      "category": "play",
      "kind": "runtime",
      "menu": true,
      "notes": "进入模型前处理的小命令；数量有上限。"
    },
    {
      "command": "amchoose",
      "description": "从短列表里选一个",
      "usage": "/amchoose A | B | C",
      "category": "play",
      "kind": "runtime",
      "menu": true,
      "notes": "进入模型前处理的小命令；有空格的项目建议用 | 或逗号分隔。"
    },
    {
      "command": "amshuffle",
      "description": "随机打乱短列表",
      "usage": "/amshuffle A | B | C",
      "category": "play",
      "kind": "runtime",
      "menu": true,
      "notes": "进入模型前处理的小命令；列表长度有上限。"
    },
    {
      "command": "amsplit",
      "description": "把名字或项目随机分组",
      "usage": "/amsplit 2 Alice Bob Carol Dave",
      "category": "play",
      "kind": "runtime",
      "menu": true,
      "notes": "进入模型前处理的小命令；第一个参数是组数。"
    },
    {
      "command": "amstats",
      "description": "统计文本字数和行数",
      "usage": "/amstats <text> or reply /amstats",
      "category": "play",
      "kind": "runtime",
      "menu": true,
      "notes": "进入模型前处理的小命令；只读取命令文本或被回复的消息。"
    },
    {
      "command": "amlinks",
      "description": "从文本中提取链接",
      "usage": "/amlinks <text> or reply /amlinks",
      "category": "play",
      "kind": "runtime",
      "menu": true,
      "notes": "进入模型前处理的小命令；只读取命令文本或被回复的消息。"
    },
    {
      "command": "ambackup",
      "description": "Export memory or project backup",
      "usage": "/ambackup memory | /ambackup github",
      "category": "ops",
      "kind": "script",
      "tool": "script_action",
      "menu": false,
      "notes": "memory => export_memory_backup. github => backup_to_github creates a local commit by default; network push is manual and outside normal chat flow."
    },
    {
      "command": "amarchive",
      "description": "Archive media cache",
      "usage": "/amarchive",
      "category": "ops",
      "kind": "script",
      "tool": "script_action",
      "scriptId": "archive_media_cache",
      "menu": false,
      "notes": "Local write script for generated/downloaded media cache."
    }
  ]
}
